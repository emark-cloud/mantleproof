{
  "name": "@mantleproof/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "MantleProof on-chain contracts (Path B: EIP-8004 registries + MantleProof)",
  "license": "MIT",
  "scripts": {
    "build": "hardhat compile",
    "compile": "hardhat compile",
    "typecheck": "tsc --noEmit",
    "lint": "solhint 'contracts/**/*.sol'",
    "test": "hardhat test",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network mantleSepolia",
    "deploy:mainnet": "hardhat run scripts/deploy.ts --network mantle",
    "smoke": "hardhat run scripts/smoke-roundtrip.ts --network mantleSepolia"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.12",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@openzeppelin/contracts": "^5.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.9",
    "@types/node": "^22.9.0",
    "chai": "^4.5.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.13.0",
    "hardhat": "^2.22.15",
    "solhint": "^5.0.3",
    "typescript": "^5.6.0"
  }
}
