# MantleProof — single repo-root env. Copy to .env (never commit .env).
# Engine reads via pydantic-settings; TS packages via dotenv -> ../.env.

# --- Network ---
MANTLE_NETWORK=mantle                        # mantle | mantleSepolia  (default: mainnet, cutover-gate cleared)
MANTLE_RPC_URL=https://rpc.mantle.xyz
MANTLE_SEPOLIA_RPC_URL=https://rpc.sepolia.mantle.xyz   # verify Week 1
MANTLE_WS_URL=wss://ws.mantle.xyz

# --- Wallets / deploy ---
DEPLOYER_PRIVATE_KEY=
ORACLE_SIGNER_PRIVATE_KEY=                   # ONLY key allowed to submitAudit
TREASURY_ADDRESS=

# --- Demo agent wallets ---
DEPLOYER_AGENT_PRIVATE_KEY=
TRADING_AGENT_PRIVATE_KEY=
YIELD_AGENT_PRIVATE_KEY=

# --- Official Mantle ERC-8004 registries (Path A — T1b RESOLVED 2026-05-18) ---
# Canonical, verified-live addresses are baked into contracts/config/registries.ts
# (per-chain). Leave these BLANK to use those defaults; set only to override.
#   Mantle mainnet 5000: identity 0x8004A169FB4a3325136EB29fA0ceB6D2e539a432
#                        reputation 0x8004BAa17C55a88189AE136b182e5fdA19dE9b63
#   Mantle Sepolia 5003: identity 0x8004A818BFB912233c491871b3d84c89A494BD9e
#                        reputation 0x8004B663056A597Dffe9eCcC1965A193B7388713
MANTLE_IDENTITY_REGISTRY=
MANTLE_REPUTATION_REGISTRY=
# MantleProof's own Mantle-issued ERC-8004 tokenId (assigned on hackathon
# registration — pending; fill once registered, then wire MantleProofAgent).
MANTLEPROOF_AGENT_TOKEN_ID=

# --- Explorer / verification (Etherscan API V2) ---
# REQUIRED: a single free etherscan.io key (V2, chainId-routed) — covers
# Mantle 5000 + Sepolia 5003. https://etherscan.io/myapikey
ETHERSCAN_API_KEY=
# Legacy V1 mantlescan key — DEPRECATED/shut down, unused. Leave blank.
MANTLESCAN_API_KEY=

# --- LLM (Gemini is DEFAULT) ---
AUDIT_LLM_PROVIDER=gemini                     # gemini | claude | zai
GEMINI_API_KEY=
ANTHROPIC_API_KEY=                            # optional, only if AUDIT_LLM_PROVIDER=claude
ZAI_API_KEY=                                  # optional, only if AUDIT_LLM_PROVIDER=zai

# --- IPFS ---
PINATA_JWT=
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# --- x402 (settles USDC on Base) ---
X402_FACILITATOR=x402org                      # x402org (Base Sepolia, free) | cdp (Base mainnet)
X402_FACILITATOR_URL=https://x402.org/facilitator
BASE_RPC_URL=https://mainnet.base.org
X402_PAYTO_ADDRESS=                           # Base address receiving USDC
X402_USDC_ADDRESS=                            # Base USDC contract
# CDP facilitator — required only when X402_FACILITATOR=cdp.
# Secret API Key from portal.cdp.coinbase.com (Ed25519 — single-line secret).
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# --- Frontend (VITE_ prefixed, build-time) ---
VITE_API_BASE_URL=http://localhost:8000
VITE_MANTLE_CHAIN_ID=5003
VITE_REGISTRY_ADDRESS=
